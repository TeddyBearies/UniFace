# Public browser-safe values
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_project_key
# Legacy fallback if your project still uses the older key naming.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key

# Server-only values
# Never expose this in client components, public bundles, or browser requests.
SUPABASE_SECRET_KEY=sb_secret_your_server_key
# Legacy fallback if your project still uses the older key naming.
# SUPABASE_SERVICE_ROLE_KEY=your_legacy_service_role_key

# Optional direct Postgres connection for local scripts, migrations, or admin-only jobs.
# Keep this server-only as well.
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
